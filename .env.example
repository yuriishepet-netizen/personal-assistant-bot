# === Telegram ===
# Получить у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram IDs пользователей с доступом (через запятую). Пусто = все могут.
# Узнать свой ID: отправь /start боту @userinfobot
ALLOWED_TELEGRAM_IDS=[]

# === Database ===
# Railway PostgreSQL: вкладка Variables → DATABASE_URL
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/assistant

# === Google Gemini ===
# Получить: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here

# === Google Calendar OAuth ===
# Создать: https://console.cloud.google.com/apis/credentials
# 1. Создать проект → APIs & Services → Credentials → OAuth 2.0 Client ID
# 2. Тип: Web Application
# 3. Redirect URI: http://localhost:8000/api/auth/google/callback (для разработки)
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# === JWT ===
# Сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-random-string

# === App ===
API_HOST=0.0.0.0
API_PORT=8000
TIMEZONE=Europe/Kyiv
